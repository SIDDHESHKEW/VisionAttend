# ═══════════════════════════════════════════════════════
#  VisionAttend — .gitignore
#  Covers: Node.js backend, React frontend, Python AI
# ═══════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────
# 🔐 ENVIRONMENT & SECRETS (NEVER commit these)
# ───────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
*.env


# ───────────────────────────────────────────────────────
# 📦 NODE.JS / NPM (backend + frontend)
# ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
.npm


# ───────────────────────────────────────────────────────
# ⚛️ REACT / VITE (frontend build output)
# ───────────────────────────────────────────────────────
dist/
dist-ssr/
*.local
.vite/


# ───────────────────────────────────────────────────────
# 🐍 PYTHON / FASTAPI (AI microservice)
# ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
virtualenv/

# Python eggs & packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Pytest / testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json


# ───────────────────────────────────────────────────────
# 🤖 AI MODEL WEIGHTS (large files — don't commit)
# ───────────────────────────────────────────────────────
*.onnx
*.pt
*.pth
*.bin
*.h5
*.pkl
*.model
models/
weights/
checkpoints/

# InsightFace model cache
.insightface/


# ───────────────────────────────────────────────────────
# 📸 UPLOADS (user data — never commit)
# ───────────────────────────────────────────────────────
backend/uploads/
uploads/
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.mp4
*.avi


# ───────────────────────────────────────────────────────
# 📊 GENERATED FILES
# ───────────────────────────────────────────────────────
*.xlsx
*.csv
*.pdf
attendance_*.xlsx


# ───────────────────────────────────────────────────────
# 🗄️ DATABASE
# ───────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.sql
postgres-data/


# ───────────────────────────────────────────────────────
# 🖥️ OS FILES
# ───────────────────────────────────────────────────────

# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*


# ───────────────────────────────────────────────────────
# 🛠️ EDITOR / IDE
# ───────────────────────────────────────────────────────

# VS Code (keep settings, ignore workspace personal files)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.history/

# JetBrains (PyCharm, WebStorm)
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#


# ───────────────────────────────────────────────────────
# 📝 LOGS
# ───────────────────────────────────────────────────────
logs/
*.log
log/
uvicorn.log
server.log


# ───────────────────────────────────────────────────────
# 🧪 TESTING
# ───────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/


# ───────────────────────────────────────────────────────
# 🐳 DOCKER (if added later)
# ───────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml


# ───────────────────────────────────────────────────────
# 🌐 MISC
# ───────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.cache
.cache/
download.html